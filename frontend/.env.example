# Copy to .env.local for local dev. Only public frontend variables.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or Supabase publishable key (same role as anon for client SDK):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: separate backend when you add one (server-side secrets stay off the frontend)
NEXT_PUBLIC_BACKEND_URL=

# Supabase Storage: create an "avatars" bucket (see backend/migrations/20260603100000_profile_avatars.sql)

# NEVER in frontend — server / Vercel only (no NEXT_PUBLIC_ prefix):
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# RAZORPAY_SECRET=
# DATABASE_PASSWORD=
